# Telegram Bot 토큰 (@BotFather에서 발급받은 토큰)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram 채널 ID (형식: -1001234567890)
TELEGRAM_CHANNEL_ID=-1001234567890

# 데이터베이스 경로 (기본값: news_crew.db)
DB_PATH=news_crew.db

# 크롤링 간격 (분, 기본값: 5)
CRAWL_INTERVAL_MINUTES=5

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 로그 파일 경로 (기본값: logs/news_crew.log)
LOG_FILE=logs/news_crew.log

# MyMemory 번역 API 키 (선택사항, 무료 tier도 작동)
# MYMEMORY_API_KEY=your_api_key_here

# MyMemory 이메일 (API 키 사용 시 필요)
# MYMEMORY_EMAIL=your_email@example.com